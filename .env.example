# Copy this file to .env and fill in real values.

# ── Local development ──────────────────────────────────────────────────────────
# SQLite — no extra database install required.
DATABASE_URL=sqlite:///smart_money.db

# ── Production (Railway PostgreSQL) ───────────────────────────────────────────
# Uncomment and paste the connection string from your Railway project.
# Railway emits postgres:// — the app normalises it to postgresql+psycopg2://.
# DATABASE_URL=postgres://user:password@host:port/dbname
