# Copy this file to .env and fill in real values.

# ── Local development ──────────────────────────────────────────────────────────
# SQLite — no extra database install required.
DATABASE_URL=sqlite:///smart_money.db

# ── Production (Supabase PostgreSQL) ──────────────────────────────────────────
# Use the session-pooler URL from Supabase dashboard → Settings → Database.
# The app normalises postgres:// to postgresql+psycopg2:// automatically.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# ── OpenFIGI API key (optional, but strongly recommended) ─────────────────────
# Free tier: https://www.openfigi.com/api  — 250 req/min with key vs 25 without.
# Without a key, resolving ~4 700 CUSIPs takes ~20 min instead of ~2 min.
OPENFIGI_API_KEY=your_key_here

# ── CORS allowed origins (production backend) ─────────────────────────────────
# Comma-separated list of origins the API accepts cross-origin requests from.
# Defaults to a hardcoded list in backend/app/core/config.py if not set.
# Set this on Render to include your Vercel URL and any preview URLs.
# ALLOWED_ORIGINS=https://smart-money-tracker-vxr6.vercel.app,https://preview.vercel.app
